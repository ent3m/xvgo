@using Microsoft.FluentUI.AspNetCore.Components.DesignTokens

@inject ControlCornerRadius ControlCornerRadius
@inject LayerCornerRadius LayerCornerRadius
@inject BaseLayerLuminance BaseLayerLuminance
@inject IDialogService DialogService
@inject XVGO.Models.ConversionSettings ConversionSettings
@inject XVGO.Services.IHistoryManager HistoryManager

@inherits LayoutComponentBase

<FluentDesignTheme StorageName="app-theme"
                   @bind-Mode="@_mode"
                   CustomColor="@(_mode == DesignThemeModes.Dark ? "#A1C9FF" : "#4FA0FF")"
                   NeutralBaseColor="@(_mode == DesignThemeModes.Dark ? "#131314" : "#FFFFFF")"
                   OnLoaded="OnAppLoaded" />

<FluentLayout Style="height: 100vh">
    <FluentHeader Style="background: var(--neutral-layer-2);">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
            <FluentButton OnClick="OpenHistoryPanelAsync" Appearance="Appearance.Lightweight">
                <FluentIcon Value="@(new AppIcons.History())" />
            </FluentButton>
            <FluentButton OnClick="ToggleTheme" Appearance="Appearance.Lightweight">
                <FluentIcon Value="@(_mode == DesignThemeModes.Dark ? (Icon)new AppIcons.Moon() : (Icon)new AppIcons.Sun())" />
            </FluentButton>
            <FluentSpacer />
            <FluentAnchor Href="https://github.com/ent3m/xvgo/" title="Source Code" Target="_blank" Rel="noopener" IconStart="@(new AppIcons.GitHub())" Appearance="Appearance.Lightweight" />
            <FluentButton OnClick="OpenSettingsPanelAsync" Appearance="Appearance.Lightweight">
                <FluentIcon Value="@(new AppIcons.Settings())" />
            </FluentButton>
        </FluentStack>
    </FluentHeader>
    <FluentBodyContent Style="background: var(--neutral-layer-1);">
        @Body
    </FluentBodyContent>
    <FluentFooter Style="background: var(--neutral-layer-2);">
        <FluentStack VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new AppIcons.XVGO())" />
            <FluentLabel Style="color: var(--neutral-foreground-hint);">@("XVGO" + _version)</FluentLabel>
            <FluentSpacer />
            <FluentLabel Style="color: var(--neutral-foreground-hint);">SVG to XAML converter for .NET developers</FluentLabel>
        </FluentStack>
    </FluentFooter>
</FluentLayout>

<FluentDialogProvider />

@code
{
    private DesignThemeModes _mode = DesignThemeModes.System;
    private IDialogReference? _dialog;
    private string? _version;

    private void ToggleTheme()
    {
        _mode = _mode == DesignThemeModes.Dark ? DesignThemeModes.Light : DesignThemeModes.Dark;
        _ = ApplyTheme();
    }

    private void OnAppLoaded(LoadedEventArgs args)
    {
		_version = $" v{System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString(3)}" ?? string.Empty;

        _ = ApplyTheme();
    }

    private async Task ApplyTheme()
    {
        await ControlCornerRadius.WithDefault(14);
        await LayerCornerRadius.WithDefault(24);

        if (_mode == DesignThemeModes.Dark)
            await BaseLayerLuminance.WithDefault(0.18f);
        else
            await BaseLayerLuminance.WithDefault(0.98f);
    }

    private async Task OpenSettingsPanelAsync()
    {
        _dialog = await DialogService.ShowPanelAsync<XVGO.Pages.Settings>(ConversionSettings, new DialogParameters<XVGO.Models.ConversionSettings>()
        {
			Content = ConversionSettings,
            Alignment = HorizontalAlignment.Right,
            Title = "Settings",
            PrimaryAction = null,
            SecondaryAction = null,
        });
        await _dialog.Result;
    }

    private async Task OpenHistoryPanelAsync()
    {
        _dialog = await DialogService.ShowPanelAsync<XVGO.Pages.History>(HistoryManager, new DialogParameters<XVGO.Services.IHistoryManager>()
        {
            Content = HistoryManager,
            Alignment = HorizontalAlignment.Left,
            Title = "History",
            PrimaryAction = null,
            SecondaryAction = null,
		});
        await _dialog.Result;
    }
}